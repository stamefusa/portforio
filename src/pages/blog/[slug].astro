---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getWorksList } from '../../lib/microcms';

export async function getStaticPaths() {
  const works = await getWorksList();

  return works.contents.map((work) => ({
    params: { slug: work.id },
    props: { work },
  }));
}

const { work } = Astro.props;
---

<BaseLayout title={`${work.title} | stamefusa.jp`} description={work.description}>
  <article class="article">
    <h1 class="article__title">{work.title}</h1>
    <div class="article__meta">
      <span class="article__date">
        {new Date(work.publishedAt || work.createdAt).toLocaleDateString('ja-JP')}
      </span>
    </div>
    <img
      class="article__thumbnail"
      src={work.thumbnail?.url ? `${work.thumbnail.url}?fm=webp&fit=crop&w=640` : '/no-image.png'}
      alt=""
    />
    <div class="rich-content" set:html={work.content} />
  </article>
</BaseLayout>
