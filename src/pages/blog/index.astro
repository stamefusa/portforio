---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkCard from '../../components/WorkCard.astro';
import { getWorksList } from '../../lib/microcms';

const works = await getWorksList();
---

<BaseLayout title="Blog | stamefusa.jp" description="ブログ記事の一覧ページです。">
  <section class="page-heading">
    <h1>Machines</h1>
    <p>{works.totalCount}件の記事を掲載しています。</p>
  </section>
  <ul class="works-grid">
    {works.contents.map((work) => <WorkCard work={work} />)}
  </ul>
  <p class="page-note">記事一覧は microCMS の blog エンドポイントからビルド時に取得しています。</p>
</BaseLayout>
