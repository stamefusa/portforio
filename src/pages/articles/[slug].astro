---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getWorksList } from '../../lib/microcms';

function formatDate(date: string) {
  const value = new Date(date);
  const year = value.getFullYear();
  const month = String(value.getMonth() + 1).padStart(2, '0');
  const day = value.getDate();

  return `${year}/${month}/${day}`;
}

function getMetaDescription(work: { description?: string; content: string }) {
  if (work.description?.trim()) {
    return work.description.trim();
  }

  const plainText = work.content
    .replace(/<[^>]+>/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

  return plainText.slice(0, 120) || 'stamefusa のポートフォリオサイトです。';
}

export async function getStaticPaths() {
  const works = await getWorksList();

  return works.contents.map((work) => ({
    params: { slug: work.id },
    props: { work },
  }));
}

const { work } = Astro.props;
---

<BaseLayout
  title={`${work.title} | stamefusa.jp`}
  description={getMetaDescription(work)}
  canonicalPath={`/articles/${work.id}/`}
  ogImage={work.thumbnail?.url || '/og-default.jpg'}
  ogType="article"
>
  <article class="article">
    <h1 class="article__title">{work.title}</h1>
    <div class="article__meta">
      <span class="article__date">
        {formatDate(work.publishedAt || work.createdAt)}
      </span>
    </div>
    {work.thumbnail?.url ? (
      <picture>
        <source
          type="image/webp"
          media="(max-width: 540px)"
          srcset={`${work.thumbnail.url}?fm=webp&w=540 1x, ${work.thumbnail.url}?fm=webp&w=540&dpr=2 2x`}
        />
        <source
          type="image/webp"
          srcset={`${work.thumbnail.url}?fm=webp&w=640 1x, ${work.thumbnail.url}?fm=webp&w=640&dpr=2 2x`}
        />
        <img
          class="article__thumbnail"
          src={work.thumbnail.url}
          alt=""
          width={work.thumbnail.width}
          height={work.thumbnail.height}
        />
      </picture>
    ) : (
      <img class="article__thumbnail" src="/no-image.png" alt="No Image" />
    )}
    <div class="rich-content" set:html={work.content} />
  </article>
</BaseLayout>
