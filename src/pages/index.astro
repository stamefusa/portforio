---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkCard from '../components/WorkCard.astro';
import { getWorksList } from '../lib/microcms';

const works = await getWorksList();
---

<BaseLayout
  title="stamefusa.jp"
  description="爲房新太朗が作ってきた、明るく笑えるギャグソウチたちを紹介します。"
>
  <section class="intro">
    <div class="intro__body">
      <span>爲房 新太朗がこれまでに</span>
      <span>作ってきたギャグソウチ</span>
    </div>
  </section>
  <ul class="works-grid">
    {works.contents.map((work) => <WorkCard work={work} />)}
  </ul>
</BaseLayout>
