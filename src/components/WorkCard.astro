---
import type { Work } from '../lib/microcms';

type Props = {
  work: Work;
  priority?: boolean;
};

const { work, priority = false } = Astro.props;

const THUMBNAIL_WIDTHS = [360, 480, 600, 720] as const;
const THUMBNAIL_HEIGHTS = {
  360: 203,
  480: 270,
  600: 338,
  720: 405,
} as const;
const THUMBNAIL_SIZES =
  '(min-width: 1080px) 240px, (min-width: 810px) 237px, (min-width: 540px) 240px, calc(90vw - 30px)';
const THUMBNAIL_QUALITY = 35;

function getThumbnailUrl(url: string, width: (typeof THUMBNAIL_WIDTHS)[number]) {
  const height = THUMBNAIL_HEIGHTS[width];
  return `${url}?fm=webp&fit=crop&w=${width}&h=${height}&q=${THUMBNAIL_QUALITY}`;
}

const thumbnailBaseUrl = work.thumbnail?.url;
const thumbnailSrc = thumbnailBaseUrl ? getThumbnailUrl(thumbnailBaseUrl, 600) : null;
const thumbnailSrcSet = thumbnailBaseUrl
  ? THUMBNAIL_WIDTHS.map((width) => `${getThumbnailUrl(thumbnailBaseUrl, width)} ${width}w`).join(', ')
  : null;
---

<li class="work-card">
  <article>
    <a class="work-card__link" href={`/articles/${work.id}/`}>
      {thumbnailSrc && thumbnailSrcSet ? (
        <picture>
          <source type="image/webp" srcset={thumbnailSrcSet} sizes={THUMBNAIL_SIZES} />
          <img
            class="work-card__image"
            src={thumbnailSrc}
            srcset={thumbnailSrcSet}
            sizes={THUMBNAIL_SIZES}
            alt=""
            width="720"
            height="405"
            loading={priority ? 'eager' : 'lazy'}
            fetchpriority={priority ? 'high' : undefined}
            decoding={priority ? 'sync' : 'async'}
          />
        </picture>
      ) : (
        <img
          class="work-card__image"
          src="/no-image.png"
          alt="No Image"
          loading={priority ? 'eager' : 'lazy'}
          fetchpriority={priority ? 'high' : undefined}
          decoding={priority ? 'sync' : 'async'}
        />
      )}
      <div class="work-card__body">
        <h2 class="work-card__title">{work.title}</h2>
      </div>
    </a>
  </article>
</li>
